\defbeamertemplate*{footline}{normal}
{%
  \leavevmode%
  \hbox{\begin{beamercolorbox}
      [wd=.5\paperwidth,ht=0.55cm,dp=0.25cm,left,leftskip=.8cm
      plus1fill]{author in head/foot}% 
