  \regex_replace_all:nnN {\s} {\~} \l_@@_embargostartdate_tl
  \regex_replace_all:nnN {\s} {\~} \l_@@_embargoenddate_tl
  \tl_gset_eq:NN \embargotempstart \l_@@_embargostartdate_tl
  \tl_gset_eq:NN \embargotempend \l_@@_embargoenddate_tl
}
