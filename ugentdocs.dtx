\begin{frame}[t]
  {Headings}
  {on two levels}
  You can set headings on two levels, by using
  \begin{itemize}
  \item\command{heading\{\}}
  \item\command{subheading\{\}}
  \end{itemize}
  \heading{Main subject}~\\
  blabla
  \subheading{Subtopic 1}~\\
  blabla
  \subheading{Subtopic 2}~\\
  blabla
  \heading{Next main subject}~\\
  blabla
\end{frame}

