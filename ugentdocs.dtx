%
% \subsection{Data dictionary and parser}
%
% Let's start by defining our dictionary:
%    \begin{macrocode}
%<*crs|bmt|phd|rp|le|ex>
\ExplSyntaxOn
\prop_new:N \g_@@_dict_keyvals_prop
\seq_new:N  \g_@@_loaded_dicts_seq
\seq_new:N  \l_@@_value_paragraphs_seq
%</crs|bmt|phd|rp|le|ex>%
%    \end{macrocode}
%
% The dictionary can be accessed using the following document command:
%    \begin{macrocode}
%<*crs|bmt|phd|rp|le|ex>
\cs_new:Npn \_@@_translate:nn #1#2 {
	\tl_set:Nx \l_@@_value_cased_tl { \prop_item:Nn \g_@@_dict_keyvals_prop {#2} }
	\tl_if_empty:nF {#1} {
		\str_case:nnF {#1}{
			{uppercase}{\tl_set:Nx \l_@@_value_cased_tl{\str_uppercase:f{\l_@@_value_cased_tl}}}
			{lowercase}{\tl_set:Nx \l_@@_value_cased_tl{\str_lowercase:f{\l_@@_value_cased_tl}}}
		}{
		}
	}
	\regex_split:nVN { __NEWLINE__ } \l_@@_value_cased_tl \l_@@_value_paragraphs_seq
	\seq_use:Nn \l_@@_value_paragraphs_seq { \newline\newline }
}
\cs_generate_variant:Nn \_@@_translate:nn { xn, xx }

\bool_new:N \l_@@_expand_bool
\tl_new:N \l_@@_case_tl

\NewDocumentCommand{\translatekey}{O{} m}{
	\bool_set_false:N \l_@@_expand_bool
	\tl_clear:N \l_@@_case_tl
	\clist_map_inline:nn {#1} {
		\str_case:nnF {##1}{
		  {expand}    { \bool_set_true:N \l_@@_expand_bool 		}
		  {uppercase} { \tl_set:Nn \l_@@_case_tl {uppercase} 	}
		  {lowercase} { \tl_set:Nn \l_@@_case_tl {lowercase} 	}
		}{
		  \msg_error:nnn {ugentdocs}{Unknown~translatekey~option}{##1}
		}
	}
	\bool_if:NTF \l_@@_expand_bool {
	  \_@@_translate:xx {\l_@@_case_tl} {#2}
	}{ 
	  \_@@_translate:xn {\l_@@_case_tl} {#2}
	}
}
%</crs|bmt|phd|rp|le|ex>%
%    \end{macrocode}
%
% To this end, we use the following parsing infrastructure:
%    \begin{macrocode}
%<*crs|bmt|phd|rp|le|ex>
\NewDocumentCommand{\useugentdocsdictionary}{m}{
  \seq_if_in:NnTF \g_@@_loaded_dicts_seq {#1}{
  }{
  	\@@_dictreader:n {#1}
  	\seq_gput_right:Nn \g_@@_loaded_dicts_seq {#1}
  }
}	

\tl_new:N \l_@@_key_tl
\tl_new:N \l_@@_value_tl
\bool_new:N \l_@@_keyval_flushpending_bool

\cs_new_nopar:Nn \@@_flush_value: {
	\bool_if:NT \l_@@_keyval_flushpending_bool {
		\tl_trim_spaces:N \l_@@_value_tl
		\prop_gput:Nxx \g_@@_dict_keyvals_prop { \l_@@_key_tl } { \l_@@_value_tl }
		\bool_set_false:N \l_@@_keyval_flushpending_bool
	}
}

\cs_generate_variant:Nn \prop_gput:Nnn{Nxx}
\cs_new_nopar:Npn \@@_dictparser:w #1 = #2 \q_stop {
  \tl_set:Nn \l_@@_key_tl{#1}
  \tl_set:Nn \l_@@_value_tl{#2}
  \tl_trim_spaces:N \l_@@_key_tl
  \tl_trim_spaces:N \l_@@_value_tl
}
%</crs|bmt|phd|rp|le|ex>
%    \end{macrocode}
% invoked by the following data file reader:
%    \begin{macrocode}
%<*crs|bmt|phd|rp|le|ex>
\ior_new:N \l_@@_dict_ior
\cs_new_nopar:Nn \@@_dictreader:n {
	\bool_set_false:N \l_@@_keyval_flushpending_bool
	\ior_open:Nn \l_@@_dict_ior { ugentdocs-#1.dict }
	\ior_str_map_inline:Nn \l_@@_dict_ior {
		\tl_if_blank:nTF {##1}{
	 		\@@_flush_value: 
		}{
			\regex_match:nnTF {=} {##1}{
				\@@_flush_value:
				\@@_dictparser:w ##1 \q_stop
				\bool_set_true:N \l_@@_keyval_flushpending_bool
			}{
				\tl_put_right:Nx \l_@@_value_tl { ~ ##1 } 
			}
		}
	}
	\@@_flush_value:
	\ior_close:N \l_@@_dict_ior
}
%</crs|bmt|phd|rp|le|ex>
%    \end{macrocode}
% By default, we load the generic (not yet implemented!) and the english data file:
%    \begin{macrocode}
%<*crs|bmt|phd|rp|le|ex>
\clist_map_inline:nn {en} {
  \@@_dictreader:n { #1 }
  \seq_gput_right:Nn \g_@@_loaded_dicts_seq { #1 }
}
